  vd_q5_nao(["LARANJA<br/>Pessoa vulnerável sem conseguir<br/>reter líquidos deve ser vista já."]):::laranja
  vd_q5 -->|Não| vd_q5_nao
  vd_q6_sim(["LARANJA<br/>Possível hemorragia digestiva."]):::laranja
  vd_q6 -->|Sim| vd_q6_sim
  vd_q6 -->|Não| vd_q7
  vd_q7_sim(["LARANJA<br/>Sinais de desidratação grave ou de<br/>mal-estar importante."]):::laranja
  vd_q7 -->|Sim| vd_q7_sim
  vd_q7 -->|Não| vd_q8
